# ===========================================
# SolarVoice AI - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values

# ===========================================
# SUPABASE CONFIGURATION
# ===========================================
# These are automatically set when you connect Supabase integration in v0
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Optional: For local development redirect URL
# NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL=http://localhost:3000/dashboard

# ===========================================
# RETELL AI CONFIGURATION
# ===========================================
# Get your API key from the Retell AI dashboard: https://app.retellai.com
RETELL_API_KEY=your_retell_api_key

# Your Retell AI agent ID for the solar sales agent
# Create an agent in the Retell dashboard and copy its ID
RETELL_AGENT_ID=your_retell_agent_id

# Your Retell phone number in E.164 format (e.g., +14157774444)
# Purchase a number from Retell or import your existing number
RETELL_FROM_NUMBER=+1XXXXXXXXXX

# ===========================================
# NOTES
# ===========================================
# 
# 1. SUPABASE SETUP:
#    - The Supabase integration is already connected via v0
#    - Environment variables are automatically injected
#    - No manual setup required for auth
#
# 2. RETELL AI SETUP:
#    a. Sign up at https://www.retellai.com
#    b. Create a new agent for solar sales
#    c. Configure the agent with your prompt and voice settings
#    d. Purchase or import a phone number
#    e. Copy your API key, agent ID, and phone number
#
# 3. DYNAMIC VARIABLES:
#    The following variables are passed to your Retell agent:
#    - phone_number: Lead's phone number
#    - first_name: Lead's first name
#    - last_name: Lead's last name
#    - city: Lead's city
#    - state: Lead's state
#    - monthly_bill: Lead's monthly electric bill
#    - property_type: Type of property (Single Family, Townhouse, etc.)
#    - roof_size: Estimated roof size in square feet
#
#    Make sure your Retell agent prompt uses these variables like:
#    "Hello {{first_name}}, I'm calling about solar installation..."
